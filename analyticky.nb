        RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ab", "=", 
          RowBox[{"OptionValue", "[", "\"\<AlphaBounds\>\"", "]"}]}], ",", 
