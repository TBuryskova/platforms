mutate(profit=w*0.5*(q_H+q_L)+lambda*(
q_H * log(2*q_H / (q_H+q_L)) + (1 - q_H) * log(2*(1 - q_H) / (1 - (q_H+q_L))) +
q_L * log(2*q_L / (q_H+q_L)) + (1 - q_L) * log(2*(1 - q_L) / (1 - (q_H+q_L))))
)
opt_row <-  w_lambda[which.max(w_lambda$profit), ]
w <- opt_row$w
