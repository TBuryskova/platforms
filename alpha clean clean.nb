          RowBox[{"q", ">=", "1."}]}], ",", "0.", ",", 
         RowBox[{
          RowBox[{"p", " ", 
           RowBox[{"Log", "[", 
            RowBox[{"p", "/", "q"}], "]"}]}], "+", 
