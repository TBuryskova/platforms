          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"PiTotal", "[", 
              RowBox[{"\[Alpha]", ",", "w", ",", "\[Lambda]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"0", "<=", "\[Alpha]", "<=", "0.95"}], "&&", 
              RowBox[{"0", "<=", "w", "<=", "0.5"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Alpha]", ",", "w"}], "}"}], ",", 
           RowBox[{"Method", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<NelderMead\>\"", ",", 
              RowBox[{"\"\<RandomSeed\>\"", "->", "1234"}]}], "}"}]}], ",", 
           RowBox[{"MaxIterations", "->", "120"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Alpha]Star", "=", 
         RowBox[{"\[Alpha]", "/.", " ", 
          RowBox[{"sol", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"wStar", "=", 
         RowBox[{"w", "/.", " ", 
          RowBox[{"sol", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Lambda\>\"", "->", "\[Lambda]"}], ",", 
          RowBox[{"\"\<Alpha\>\"", "->", "\[Alpha]Star"}], ",", 
