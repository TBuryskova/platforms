Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "Ueq", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ueq", "[", 
     RowBox[{
      RowBox[{"\[Alpha]_", "?", "NumericQ"}], ",", 
      RowBox[{"w_", "?", "NumericQ"}], ",", 
      RowBox[{"\[Lambda]_", "?", "NumericQ"}]}], "]"}], "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
