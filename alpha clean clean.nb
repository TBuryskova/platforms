        RowBox[{"\[Alpha]", ",", "w", ",", "\[Lambda]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"xs", "=", 
       RowBox[{"N", "@", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"0", ",", "1", ",", "n"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"KLlocal", "[", 
        RowBox[{
         RowBox[{"p_", "?", "NumericQ"}], ",", 
         RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
       RowBox[{"If", "[", 
