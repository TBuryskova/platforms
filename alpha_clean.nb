Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"regionMassData", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l", "=", 
           RowBox[{"diagData", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<Lambda\>\""}], "]"}], "]"}]}], ",", 
          RowBox[{"e0", "=", 
           RowBox[{"diagData", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<eps0\>\""}], "]"}], "]"}]}], ",", 
          RowBox[{"e1", "=", 
           RowBox[{"diagData", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<eps1\>\""}], "]"}], "]"}]}], ",", 
          "always", ",", "interior", ",", "outside"}], "}"}], ",", 
        RowBox[{
         RowBox[{"always", "=", 
          RowBox[{"Max", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Min", "[", 
             RowBox[{"e0", ",", "1"}], "]"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"interior", "=", 
          RowBox[{"Max", "[", 
           RowBox[{"0", ",", 
            RowBox[{
             RowBox[{"Min", "[", 
              RowBox[{"e1", ",", "1"}], "]"}], "-", 
             RowBox[{"Max", "[", 
              RowBox[{"0", ",", "e0"}], "]"}]}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"outside", "=", 
          RowBox[{"1", "-", 
           RowBox[{"Max", "[", 
            RowBox[{"0", ",", 
             RowBox[{"Min", "[", 
              RowBox[{"e1", ",", "1"}], "]"}]}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"l", ",", "always", ",", "interior", ",", "outside"}], 
          "}"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "diagData", "]"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
