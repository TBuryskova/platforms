Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"TotalPi", "[", 
     RowBox[{"w_", ",", "\[Lambda]_", ",", "p_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], "*", 
      RowBox[{"PiI", "[", 
       RowBox[{"w", ",", "\[Lambda]"}], "]"}]}], "+", 
     RowBox[{"p", "*", 
      RowBox[{"Pif", "[", 
       RowBox[{"w", ",", "\[Lambda]"}], "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"opt", "[", 
     RowBox[{"p_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"FindMaximum", "[", 
       RowBox[{
        RowBox[{"TotalPi", "[", 
         RowBox[{"w", ",", "\[Lambda]", ",", "p"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"w", ",", "0.2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Lambda]", ",", "0.1"}], "}"}]}], "}"}]}], "]"}], 
      "\[IndentingNewLine]", 
      RowBox[{"maxValue", "[", 
       RowBox[{"p_", "?", "NumericQ"}], "]"}]}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"First", "@", 
        RowBox[{"opt", "[", "p", "]"}]}], "\n", "\[IndentingNewLine]", 
       RowBox[{"wStar", "[", 
        RowBox[{"p_", "?", "NumericQ"}], "]"}]}], ":=", 
      RowBox[{
       RowBox[{"w", "/.", " ", 
        RowBox[{
         RowBox[{"Last", "@", 
          RowBox[{"opt", "[", "p", "]"}]}], "\n", "\[IndentingNewLine]", 
         RowBox[{"\[Lambda]Star", "[", 
          RowBox[{"p_", "?", "NumericQ"}], "]"}]}]}], ":=", 
       RowBox[{"\[Lambda]", "/.", " ", 
        RowBox[{
         RowBox[{"Last", "@", 
          RowBox[{"opt", "[", "p", "]"}]}], "\[IndentingNewLine]", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"wStar", "[", "p", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"p", ",", "0", ",", "1"}], "}"}]}], "]"}], "\n", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"\[Lambda]Star", "[", "p", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"p", ",", "0", ",", "1"}], "}"}]}], "]"}], "\n", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"maxValue", "[", "p", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"p", ",", "0", ",", "1"}], "}"}]}], "]"}]}]}]}]}]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"FindMaximum", "[", 
  RowBox[{
   RowBox[{"TotalPi", "[", 
    RowBox[{"w", ",", "\[Lambda]", ",", "0.3"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", "0.2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Lambda]", ",", "0.1"}], "}"}]}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"FindMaximum", "[", 
  RowBox[{
   RowBox[{"PiI", "[", 
    RowBox[{"w", ",", "\[Lambda]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", "0.2"}], "}"}], ",", 
