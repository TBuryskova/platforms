           RowBox[{"(", 
            RowBox[{"1", "-", "p"}], ")"}], " ", 
           RowBox[{"Log", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "p"}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"1", "-", "q"}], ")"}]}], "]"}]}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Which", "[", 
