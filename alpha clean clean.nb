     RowBox[{"\[Alpha]_", "?", "NumericQ"}], ",", 
     RowBox[{"w_", "?", "NumericQ"}], ",", 
     RowBox[{"\[Lambda]_", "?", "NumericQ"}], ",", 
     RowBox[{"n_", ":", "120"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
