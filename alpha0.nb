Cell["Platform profit plots", "Text",
 CellChangeTimes->{{3.9804775933292856`*^9, 
  3.9804776072007217`*^9}},ExpressionUUID->"8c805abc-5691-4d6b-92fe-\
dca5feb04485"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"makePlots", "[", 
   RowBox[{"f_", ",", "title_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "max", ",", "\[Alpha]star", ",", "wstar", ",", "maxval", ",", "p3d", ",",
       "pcont"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"--", 
        RowBox[{"-", "Find"}]}], " ", 
       RowBox[{"maximum", "--"}]}], "-"}], "*)"}], 
    RowBox[{
     RowBox[{"max", "=", 
      RowBox[{"NMaximize", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"\[Alpha]", ",", "w"}], "]"}], ",", 
          RowBox[{
           RowBox[{"0.01", "<=", "\[Alpha]", "<=", "0.99"}], "&&", 
           RowBox[{"0", "<=", "w", "<=", "1"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]", ",", "w"}], "}"}], ",", " ", 
        RowBox[{"Method", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<RandomSearch\>\"", ",", 
           RowBox[{"\"\<SearchPoints\>\"", "->", "50"}]}], "}"}]}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"maxval", "=", 
      RowBox[{"max", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]star", ",", "wstar"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", "w"}], "}"}], "/.", " ", 
       RowBox[{"max", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"--", 
         RowBox[{"-", "3"}]}], "D", " ", 
        RowBox[{"Plot", "--"}]}], "-"}], "*)"}], 
     RowBox[{"p3d", "=", 
      RowBox[{"Show", "[", 
       RowBox[{
        RowBox[{"Plot3D", "[", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"\[Alpha]", ",", "w"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", "0.01", ",", "0.99"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"w", ",", "0", ",", "1"}], "}"}], ",", 
          RowBox[{"PlotPoints", "->", "40"}], ",", 
          RowBox[{"MaxRecursion", "->", "2"}], ",", 
          RowBox[{"PlotRange", "->", "All"}], ",", 
          RowBox[{"AxesLabel", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<\[Alpha]\>\"", ",", "\"\<w\>\"", ",", "title"}], 
            "}"}]}], ",", 
          RowBox[{"PlotLabel", "->", "title"}]}], "]"}], ",", 
        RowBox[{"Graphics3D", "[", 
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
           RowBox[{"Point", "[", 
            RowBox[{"{", 
             RowBox[{"\[Alpha]star", ",", "wstar", ",", "maxval"}], "}"}], 
            "]"}]}], "}"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"--", 
         RowBox[{"-", "Contour"}]}], " ", 
        RowBox[{"Plot", "--"}]}], "-"}], "*)"}], 
     RowBox[{"pcont", "=", 
      RowBox[{"Show", "[", 
       RowBox[{
        RowBox[{"ContourPlot", "[", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"\[Alpha]", ",", "w"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", "0.01", ",", "0.99"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"w", ",", "0", ",", "1"}], "}"}], ",", 
          RowBox[{"Contours", "->", "20"}], ",", 
          RowBox[{"PlotPoints", "->", "40"}], ",", 
