        RowBox[{"\"\<SearchPoints\>\"", "->", "50"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pistar", "=", 
   RowBox[{"max", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Alpha]star", ",", "wstar"}], "}"}], "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", "w"}], "}"}], "/.", " ", 
    RowBox[{"max", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PiIstar", "=", 
   RowBox[{"\[CapitalPi]I", "[", 
    RowBox[{"\[Alpha]star", ",", "wstar"}], "]"}]}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PiFstar", "=", 
   RowBox[{"\[CapitalPi]F", "[", 
