\\!\\(\\*RowBox[{\\\"9\\\"}]\\) recursive bisections in \
\\!\\(\\*RowBox[{\\\"x\\\"}]\\) near \\!\\(\\*RowBox[{\\\"{\\\", \\\"x\\\", \
\\\"}\\\"}]\\) = \\!\\(\\*RowBox[{\\\"{\\\", \\\"1.791198126141029`*^14\\\", \
\\\"}\\\"}]\\). NIntegrate obtained \
\\!\\(\\*RowBox[{\\\"0.006331277140101576`\\\"}]\\) and \
\\!\\(\\*RowBox[{\\\"0.0005458666721210968`\\\"}]\\) for the integral and \
error estimates.\"", 2, 216, 151, 19966455889205333602, "Local"},
  "MessageTemplate"]], "Message", "MSG",
