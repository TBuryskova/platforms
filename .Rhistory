return(0)
}
ab <- get_AB(w, lambda_safe)
A <- ab$A
B <- ab$B
k_star <- (2 - (A + B)) / (2 * A * B - (A + B))
# Check for NaN and negative values in k_star which would cause issues
if (is.nan(k_star) || k_star < 0) {
return(0)
}
p_buy <- k_star / (1 + k_star)
return(p_buy)
}
# Corrected function for the conditional probability P*(B=1|H)
pB_H_RI <- function(w, lambda) {
lambda_safe <- pmax(lambda, 1e-10)
if (w > lambda_safe * log(cosh(1 / lambda_safe))) {
return(0)
}
ab <- get_AB(w, lambda_safe)
A <- ab$A
B <- ab$B
k_star <- (2 - (A + B)) / (2 * A * B - (A + B))
if (is.nan(k_star) || k_star < 0) {
return(0)
}
p_bh <- 1 / (1 + k_star * A)
return(p_bh)
}
# Corrected function for the conditional probability P*(B=1|L)
pB_L_RI <- function(w, lambda) {
lambda_safe <- pmax(lambda, 1e-10)
if (w > lambda_safe * log(cosh(1 / lambda_safe))) {
return(0)
}
ab <- get_AB(w, lambda_safe)
A <- ab$A
B <- ab$B
k_star <- (2 - (A + B)) / (2 * A * B - (A + B))
if (is.nan(k_star) || k_star < 0) {
return(0)
}
p_bl <- 1 / (1 + k_star * B)
return(p_bl)
}
# Function for Mutual Information MI*
MI_RI <- function(w, lambda) {
pBH <- pB_H_RI(w, lambda)
pBL <- pB_L_RI(w, lambda)
pBuy <- (pBH + pBL) / 2
# Handle log of zero cases
if (pBuy == 0 || pBuy == 1) {
return(0)
}
pB0H <- 1 - pBH
pB0L <- 1 - pBL
pB0 <- 1 - pBuy
# Ensure no log(0)
log_term_1 <- ifelse(pBH > 0 & pBuy > 0, pBH * log(pBH / pBuy), 0)
log_term_2 <- ifelse(pBL > 0 & pBuy > 0, pBL * log(pBL / pBuy), 0)
log_term_3 <- ifelse(pB0H > 0 & pB0 > 0, pB0H * log(pB0H / pB0), 0)
log_term_4 <- ifelse(pB0L > 0 & pB0 > 0, pB0L * log(pB0L / pB0), 0)
mi <- 0.5 * (log_term_1 + log_term_2 + log_term_3 + log_term_4)
return(mi)
}
# ---------- Platform's Profit Function ----------
# This function incorporates the user's optimal response and attention revenue
profit_RI <- function(w, lambda) {
p_buy <- pB_RI(w, lambda)
mi_val <- MI_RI(w, lambda)
profit <- w * p_buy + lambda * mi_val
return(profit)
}
# ---------- Iterated game with rational inattention ----------
run_iterated_game_RI <- function(
w0 = 0.5, lambda0 = 0.5, n_cycles = 10,
w_bounds = c(0, 1), lambda_bounds = c(0, 1),
coarse = 200,
verbose = TRUE
) {
w <- w0
lambda <- lambda0
log_df <- vector("list", n_cycles)
for (t in seq_len(n_cycles)) {
# Step 1: User's optimal response to the current w, lambda
qH <- pB_H_RI(w, lambda)
qL <- pB_L_RI(w, lambda)
# Step 2: Firm's best response, maximizing profit based on the user's rational response
ws <- seq(w_bounds[1], w_bounds[2], length.out = coarse)
ls <- seq(lambda_bounds[1], lambda_bounds[2], length.out = coarse)
grid <- expand.grid(w = ws, lambda = ls)
# Use the new, responsive profit function
grid$pi <- mapply(profit_RI, grid$w, grid$lambda)
best <- grid[which.max(grid$pi), ]
w_new <- best$w
lambda_new <- best$lambda
# Step 3: Record outcomes at current state
prof <- profit_RI(w, lambda)
pBuy <- pB_RI(w, lambda)
mi <- MI_RI(w, lambda)
# Note: V_RI and welfare_fun are not defined in the provided context
# and would need to be added to complete the log.
log_df[[t]] <- tibble::tibble(
iter = t,
w = w,
lambda = lambda,
pBH = qH,
pBL = qL,
pBuy = pBuy,
MI = mi,
profit = prof,
w_next = w_new,
lambda_next = lambda_new
)
if (verbose) {
cat(sprintf(
"Iter %02d | w=%.3f, λ=%.3f | pBH=%.3f, pBL=%.3f | π=%.3f | -> w_next=%.3f, λ_next=%.3f\n",
t, w, lambda, qH, qL, prof, w_new, lambda_new
))
}
# Step 4: Update for the next cycle
w <- w_new
lambda <- lambda_new
}
dplyr::bind_rows(log_df)
}
# ---------- Example run of the model ----------
results_RI <- run_iterated_game_RI(
w0 = 0.5, lambda0 = 0.5, n_cycles = 10,
w_bounds = c(0, 1), lambda_bounds = c(0, 1),
coarse = 200
)
print(results_RI, n = Inf)
# Full Script for the Sequential Game with Rational Inattention
# Load required libraries
library(dplyr)
library(tibble)
# ---------- Helper functions for the consumer's rational inattention model ----------
# Helper function to calculate the A and B parameters
get_AB <- function(w, lambda) {
A <- exp((-1 + w) / lambda)
B <- exp((1 + w) / lambda)
return(list(A = A, B = B))
}
# Corrected function for the unconditional buying probability P*(B=1)
pB_RI <- function(w, lambda) {
# Add a small epsilon value to lambda to prevent issues with log(cosh(1/lambda))
lambda_safe <- pmax(lambda, 1e-10)
if (w > lambda_safe * log(cosh(1 / lambda_safe))) {
return(0)
}
ab <- get_AB(w, lambda_safe)
A <- ab$A
B <- ab$B
k_star <- (2 - (A + B)) / (2 * A * B - (A + B))
# Check for NaN and negative values in k_star which would cause issues
if (is.nan(k_star) || k_star < 0) {
return(0)
}
p_buy <- k_star / (1 + k_star)
return(p_buy)
}
# Corrected function for the conditional probability P*(B=1|H)
pB_H_RI <- function(w, lambda) {
lambda_safe <- pmax(lambda, 1e-10)
if (w > lambda_safe * log(cosh(1 / lambda_safe))) {
return(0)
}
ab <- get_AB(w, lambda_safe)
A <- ab$A
B <- ab$B
k_star <- (2 - (A + B)) / (2 * A * B - (A + B))
if (is.nan(k_star) || k_star < 0) {
return(0)
}
p_bh <- 1 / (1 + k_star * A)
return(p_bh)
}
# Corrected function for the conditional probability P*(B=1|L)
pB_L_RI <- function(w, lambda) {
lambda_safe <- pmax(lambda, 1e-10)
if (w > lambda_safe * log(cosh(1 / lambda_safe))) {
return(0)
}
ab <- get_AB(w, lambda_safe)
A <- ab$A
B <- ab$B
k_star <- (2 - (A + B)) / (2 * A * B - (A + B))
if (is.nan(k_star) || k_star < 0) {
return(0)
}
p_bl <- 1 / (1 + k_star * B)
return(p_bl)
}
# Function for Mutual Information MI*
MI_RI <- function(w, lambda) {
pBH <- pB_H_RI(w, lambda)
pBL <- pB_L_RI(w, lambda)
pBuy <- (pBH + pBL) / 2
# Handle log of zero cases
if (pBuy == 0 || pBuy == 1) {
return(0)
}
pB0H <- 1 - pBH
pB0L <- 1 - pBL
pB0 <- 1 - pBuy
# Ensure no log(0)
log_term_1 <- ifelse(pBH > 0 & pBuy > 0, pBH * log(pBH / pBuy), 0)
log_term_2 <- ifelse(pBL > 0 & pBuy > 0, pBL * log(pBL / pBuy), 0)
log_term_3 <- ifelse(pB0H > 0 & pB0 > 0, pB0H * log(pB0H / pB0), 0)
log_term_4 <- ifelse(pB0L > 0 & pB0 > 0, pB0L * log(pB0L / pB0), 0)
mi <- 0.5 * (log_term_1 + log_term_2 + log_term_3 + log_term_4)
return(mi)
}
# Expected utility function for the consumer
u_fun <- function(w, lambda) {
# Expected utility is the sum of utility * probability for each outcome
pBH <- pB_H_RI(w, lambda)
pBL <- pB_L_RI(w, lambda)
# Utility from buying H is (1-w), from buying L is (-1-w)
# Utility from not buying is 0
expected_utility <- 0.5 * (pBH * (1 - w) + pBL * (-1 - w))
return(expected_utility)
}
# User's value function (Expected utility - cost of information)
V_RI <- function(w, lambda) {
user_value <- u_fun(w, lambda) - lambda * MI_RI(w, lambda)
return(user_value)
}
# ---------- Platform's Profit Function ----------
# This function incorporates the user's optimal response and attention revenue
run_iterated_game_RI_verbose <- function(
w0 = 0.5, lambda0 = 0.5, n_cycles = 10,
w_bounds = c(0, 1), lambda_bounds = c(0, 1),
coarse = 200,
verbose = TRUE
) {
w <- w0
lambda <- lambda0
log_df <- vector("list", n_cycles * 2) # Two rows per cycle: firm and user
for (t in seq_len(n_cycles)) {
# ---------- User's Turn (Action and logging) ----------
qH <- pB_H_RI(w, lambda)
qL <- pB_L_RI(w, lambda)
pBuy <- pB_RI(w, lambda)
mi <- MI_RI(w, lambda)
user_value <- V_RI(w, lambda)
log_df[[(t - 1) * 2 + 1]] <- tibble::tibble(
iter = t,
actor = "user",
w = w,
lambda = lambda,
pBH = qH,
pBL = qL,
pBuy = pBuy,
MI = mi,
profit = NA, # Profit is only for the firm
user_value = user_value
)
if (verbose) {
cat(sprintf(
"Iter %02d | User's action to w=%.3f, λ=%.3f | pBuy=%.3f | V_RI=%.3f\n",
t, w, lambda, pBuy, user_value
))
}
# ---------- Firm's Turn (Action and logging) ----------
ws <- seq(w_bounds[1], w_bounds[2], length.out = coarse)
ls <- seq(lambda_bounds[1], lambda_bounds[2], length.out = coarse)
grid <- expand.grid(w = ws, lambda = ls)
grid$pi <- mapply(profit_RI, grid$w, grid$lambda)
best <- grid[which.max(grid$pi), ]
w_new <- best$w
lambda_new <- best$lambda
prof <- profit_RI(w, lambda)
log_df[[(t - 1) * 2 + 2]] <- tibble::tibble(
iter = t,
actor = "firm",
w = w,
lambda = lambda,
pBH = NA, # These are user metrics
pBL = NA,
pBuy = NA,
MI = NA,
profit = prof,
user_value = NA,
w_next = w_new,
lambda_next = lambda_new
)
if (verbose) {
cat(sprintf(
"Firm's action: -> w_next=%.3f, λ_next=%.3f | Profit=%.3f\n\n",
w_new, lambda_new, prof
))
}
w <- w_new
lambda <- lambda_new
}
dplyr::bind_rows(log_df)
}
# Example run
results_verbose <- run_iterated_game_RI_verbose(
w0 = 0.5, lambda0 = 0.5, n_cycles = 10,
w_bounds = c(0, 1), lambda_bounds = c(0, 1),
coarse = 200
)
print(results_verbose, n = Inf)
library(tidyverse)
br_user<- function(w, lambda) {
threshold <- lambda * log(cosh(1 / lambda))
q_H=  ifelse(
w < threshold,
{
numerator <- 2 - (exp((-1 + w)/lambda) + exp((1 + w)/lambda))
denominator <- 2*exp(2*w/lambda) - (exp((-1 + w)/lambda) + exp((1 + w)/lambda))
val <- 1 / (1 + (numerator / denominator) * exp((-1 + w)/lambda))
pmin(pmax(val, 0), 1)  # clamp between 0 and 1
},
0
)
q_L =  ifelse(
w < threshold,
{
numerator <- 2 - (exp((-1 + w)/lambda) + exp((1 + w)/lambda))
denominator <- 2*exp(2*w/lambda) - (exp((-1 + w)/lambda) + exp((1 + w)/lambda))
val <- 1 / (1 + (numerator / denominator) * exp((1 + w)/lambda))
pmin(pmax(val, 0), 1)  # clamp between 0 and 1
},
0
)
return(q_H,q_L)
}
br_user(0.5,0.5)
