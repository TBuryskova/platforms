               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x", "+", "w"}], ")"}], "/", "t"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"k", "=", 
              RowBox[{"-", 
               RowBox[{"(", 
