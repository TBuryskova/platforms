         RowBox[{"Pi1", "[", 
          RowBox[{"\[Alpha]", ",", "\[Lambda]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"\[Lambda]lo", "<", "\[Lambda]", "<", "\[Lambda]hi"}], "&&", 
          RowBox[{"0", "<", "\[Alpha]", "<", "1"}], "&&", 
          RowBox[{"case1Q", "[", 
           RowBox[{"\[Alpha]", ",", "wCase1", ",", "\[Lambda]"}], "]"}]}]}], 
        "}"}], ",", 
       RowBox[{"{", "\[Alpha]", "}"}], ",", "\[Lambda]"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"symOptCase2On", "[", 
      RowBox[{"\[Lambda]lo_", ",", "\[Lambda]hi_"}], "]"}], ":=", 
     RowBox[{"ParametricMaximize", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Pi2", "[", 
          RowBox[{"\[Alpha]", ",", "w", ",", "\[Lambda]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"\[Lambda]lo", "<", "\[Lambda]", "<", "\[Lambda]hi"}], "&&", 
          RowBox[{"0", "<", "\[Alpha]", "<", "1"}], "&&", 
          RowBox[{"w", ">", "0"}], "&&", 
          RowBox[{"case2Q", "[", 
           RowBox[{"\[Alpha]", ",", "w", ",", "\[Lambda]"}], "]"}]}]}], "}"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", "w"}], "}"}], ",", "\[Lambda]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Create", " ", "symbolic", " ", "objects", " ", "per", " ", "detected", 
     " ", "interval"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"symPieces", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"c", "=", 
            RowBox[{"intervals", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "\"\<case\>\""}], "]"}], "]"}]}], ",", 
           RowBox[{"lo", "=", 
            RowBox[{"intervals", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "\"\<\[Lambda]min\>\""}], "]"}], "]"}]}], ",", 
           RowBox[{"hi", "=", 
            RowBox[{"intervals", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "\"\<\[Lambda]max\>\""}], "]"}], "]"}]}], ",",
            "sol"}], "}"}], ",", 
         RowBox[{
          RowBox[{"sol", "=", 
           RowBox[{"Which", "[", 
            RowBox[{
             RowBox[{"c", "==", "1"}], ",", 
             RowBox[{"symOptCase1On", "[", 
              RowBox[{"lo", ",", "hi"}], "]"}], ",", 
             RowBox[{"c", "==", "2"}], ",", 
             RowBox[{"symOptCase2On", "[", 
              RowBox[{"lo", ",", "hi"}], "]"}], ",", "True", ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"\[Alpha]", "->", 
                  RowBox[{"1", "/", "2"}]}], ",", 
                 RowBox[{"w", "->", "0"}]}], "}"}]}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<case\>\"", "->", "c"}], ",", 
            RowBox[{"\"\<\[Lambda]min\>\"", "->", "lo"}], ",", 
            RowBox[{"\"\<\[Lambda]max\>\"", "->", "hi"}], ",", 
            RowBox[{"\"\<opt\>\"", "->", "sol"}]}], "|>"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "intervals", "]"}]}], "}"}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"symPieces", "//", "Dataset"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Stitch", " ", "into", " ", "a", " ", "global", " ", "Piecewise", " ", 
     "solution"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PiStar", "[", "\[Lambda]_", "]"}], ":=", 
     RowBox[{"Piecewise", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"symPieces", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "\"\<opt\>\"", ",", "1"}], "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"symPieces", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<\[Lambda]min\>\""}], "]"}], "]"}], "<", 
           "\[Lambda]", "<", 
           RowBox[{"symPieces", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<\[Lambda]max\>\""}], "]"}], "]"}]}]}], 
         "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "symPieces", "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"solStar", "[", "\[Lambda]_", "]"}], ":=", 
     RowBox[{"Piecewise", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"symPieces", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "\"\<case\>\""}], "]"}], "]"}], "==", "1"}], 
            ",", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"symPieces", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "\"\<opt\>\"", ",", "2"}], "]"}], "]"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{"w", "->", "wCase1"}], "}"}]}], "]"}], ",", 
            RowBox[{"symPieces", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "\"\<opt\>\"", ",", "2"}], "]"}], "]"}]}], 
           "]"}], ",", 
          RowBox[{
           RowBox[{"symPieces", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<\[Lambda]min\>\""}], "]"}], "]"}], "<", 
           "\[Lambda]", "<", 
           RowBox[{"symPieces", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<\[Lambda]max\>\""}], "]"}], "]"}]}]}], 
         "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "symPieces", "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"alphaStar", "[", "\[Lambda]_", "]"}], ":=", 
     RowBox[{"\[Alpha]", "/.", " ", 
      RowBox[{"solStar", "[", "\[Lambda]", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"wStar", "[", "\[Lambda]_", "]"}], ":=", 
     RowBox[{"w", "/.", " ", 
      RowBox[{"solStar", "[", "\[Lambda]", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Profit", " ", "components", " ", "at", " ", "the", " ", "stitched", " ", 
     "optimum"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PiFStar", "[", "\[Lambda]_", "]"}], ":=", 
     RowBox[{"Piecewise", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"symPieces", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "\"\<case\>\""}], "]"}], "]"}], "==", "1"}], 
            ",", 
            RowBox[{"PiF1", "[", "\[Lambda]", "]"}], ",", 
            RowBox[{"PiF2", "[", 
             RowBox[{
              RowBox[{"alphaStar", "[", "\[Lambda]", "]"}], ",", 
              RowBox[{"wStar", "[", "\[Lambda]", "]"}], ",", "\[Lambda]"}], 
             "]"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"symPieces", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<\[Lambda]min\>\""}], "]"}], "]"}], "<", 
           "\[Lambda]", "<", 
           RowBox[{"symPieces", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "\"\<\[Lambda]max\>\""}], "]"}], "]"}]}]}], 
         "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "symPieces", "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PiIStar", "[", "\[Lambda]_", "]"}], ":=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"PiStar", "[", "\[Lambda]", "]"}], "-", 
        RowBox[{"PiFStar", "[", "\[Lambda]", "]"}]}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"0", "<", "\[Lambda]", "<", "1"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Final", " ", 
     RowBox[{"deliverable", ":", 
      RowBox[{"closed", "-", 
       RowBox[{"form", " ", 
        RowBox[{"(", "piecewise", ")"}], " ", "objects"}]}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PlatformOptimumHybrid", ":=", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Pi*\>\"", "->", 
        RowBox[{"PiStar", "[", "\[Lambda]", "]"}]}], ",", 
       RowBox[{"\"\<alpha*\>\"", "->", 
        RowBox[{"alphaStar", "[", "\[Lambda]", "]"}]}], ",", 
       RowBox[{"\"\<w*\>\"", "->", 
        RowBox[{"wStar", "[", "\[Lambda]", "]"}]}], ",", 
       RowBox[{"\"\<Pi_F*\>\"", "->", 
        RowBox[{"PiFStar", "[", "\[Lambda]", "]"}]}], ",", 
       RowBox[{"\"\<Pi_I*\>\"", "->", 
        RowBox[{"PiIStar", "[", "\[Lambda]", "]"}]}], ",", 
       RowBox[{"\"\<DetectedIntervals\>\"", "->", "intervals"}], ",", 
       RowBox[{"\"\<SwitchRootGuesses\>\"", "->", "switchRoots"}]}], "|>"}]}],
     ";"}], "\n", "\[IndentingNewLine]", "PlatformOptimumHybrid"}]}]], "Input",
