      RowBox[{"t", "=", 
       RowBox[{"tau", "[", 
        RowBox[{"\[Alpha]", ",", "\[Lambda]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"d", "=", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "t"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"x0", "=", 
       RowBox[{"eps0", "[", 
        RowBox[{"\[Alpha]", ",", "w", ",", "\[Lambda]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"x1", "=", 
