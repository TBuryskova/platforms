     RowBox[{"SolveJointPolicy", "[", "\[Lambda]", "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"sol", ",", "\[Alpha]Star", ",", "wStar"}], "}"}], ",", 
       RowBox[{
        RowBox[{"sol", "=", 
