                ")"}]}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"ph", "=", 
              RowBox[{"1.", "/", 
               RowBox[{"(", 
                RowBox[{"1.", "+", 
                 RowBox[{"k", " ", "d", " ", "B"}]}], ")"}]}]}], ";", 
