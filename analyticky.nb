       RowBox[{"\"\<WBounds\>\"", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"10", "^", 
           RowBox[{"-", "6"}]}], ",", "2"}], "}"}]}], ",", 
       RowBox[{"(*", 
