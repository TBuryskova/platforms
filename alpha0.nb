Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"U", "[", 
    RowBox[{"x_", ",", "w_", ",", "\[Alpha]_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"0.5", "-", "w"}], ",", 
        RowBox[{"x", "<", 
         RowBox[{"\[CurlyEpsilon]0", "[", 
          RowBox[{"\[Alpha]", ",", "w"}], "]"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"0.5", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"PHx", "[", 
              RowBox[{"\[Alpha]", ",", "w", ",", "x"}], "]"}], "*", 
             RowBox[{"(", 
              RowBox[{"1", "-", "w"}], ")"}]}], "+", 
            RowBox[{
             RowBox[{"PLx", "[", 
              RowBox[{"\[Alpha]", ",", "w", ",", "x"}], "]"}], "*", 
             RowBox[{"(", 
              RowBox[{"-", "w"}], ")"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", "-", 
               RowBox[{"PHx", "[", 
                RowBox[{"\[Alpha]", ",", "w", ",", "x"}], "]"}], "-", 
               RowBox[{"PLx", "[", 
                RowBox[{"\[Alpha]", ",", "w", ",", "x"}], "]"}]}], ")"}], "*",
              "x"}]}], ")"}]}], "-", 
         RowBox[{"\[Lambda]", "*", 
          RowBox[{"MIx", "[", 
           RowBox[{"\[Alpha]", ",", "w", ",", "x"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"\[CurlyEpsilon]0", "[", 
          RowBox[{"\[Alpha]", ",", "w"}], "]"}], "<", "x", "<", 
         RowBox[{"\[CurlyEpsilon]1", "[", 
          RowBox[{"\[Alpha]", ",", "w"}], "]"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"x", ">", 
         RowBox[{"\[CurlyEpsilon]1", "[", 
          RowBox[{"\[Alpha]", ",", "w"}], "]"}]}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FullInfo", "[", 
     RowBox[{"x_", ",", "w_"}], "]"}], ":=", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"x", "<", 
          RowBox[{"-", "w"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0.5", ",", 
         RowBox[{
          RowBox[{"-", "w"}], "<", "x", "<", 
          RowBox[{"1", "-", "w"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"x", ">", 
          RowBox[{"1", "-", "w"}]}]}], "}"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"U", "[", 
      RowBox[{"x", ",", "0.32", ",", "0.4"}], "]"}], ",", "x", ",", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", "x"}], ")"}], "/", "2"}]}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", " ", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1"}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", 
      RowBox[{"{", 
       RowBox[{"Black", ",", "Dashed", ",", 
        RowBox[{"Opacity", "[", "0.6", "]"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"Black", ",", "Dotted", ",", 
        RowBox[{"Opacity", "[", "0.6", "]"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\[CurlyEpsilon]\>\"", ",", "\"\<E[U[\[CurlyEpsilon]]]*\>\""}], 
     "}"}]}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<equilibrium\>\"", ",", "\"\<no market\>\"", ",", 
      "\"\<no ads, no fee\>\""}], "}"}]}]}], "]"}]}], "Input",
