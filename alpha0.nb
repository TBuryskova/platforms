Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"maxm", "=", 
   RowBox[{"NMaximize", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]I", "[", 
        RowBox[{"\[Alpha]", ",", "0"}], "]"}], ",", 
       RowBox[{"0.01", "<=", "\[Alpha]", "<=", "0.99"}]}], "}"}], ",", 
     "\[Alpha]", ",", 
     RowBox[{"Method", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<RandomSearch\>\"", ",", 
        RowBox[{"\"\<SearchPoints\>\"", "->", "50"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]starm", "=", 
   RowBox[{"\[Alpha]", "/.", " ", 
    RowBox[{"maxm", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pistarm", "=", 
   RowBox[{"maxm", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], " ", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxp", "=", 
   RowBox[{"NMaximize", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]F", "[", 
        RowBox[{"0", ",", "w"}], "]"}], ",", 
       RowBox[{"0.01", "<=", "w", "<=", "0.99"}]}], "}"}], ",", "w", ",", 
     RowBox[{"Method", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<RandomSearch\>\"", ",", 
        RowBox[{"\"\<SearchPoints\>\"", "->", "50"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"wstarp", "=", 
   RowBox[{"w", "/.", " ", 
    RowBox[{"maxp", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pistarp", "=", 
   RowBox[{"maxp", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], " ", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"max", "=", 
   RowBox[{"NMaximize", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]", "[", 
        RowBox[{"\[Alpha]", ",", "w"}], "]"}], ",", 
       RowBox[{
        RowBox[{"0.01", "<=", "\[Alpha]", "<=", "0.99"}], "&&", 
        RowBox[{"0", "<=", "w", "<=", "1"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", "w"}], "}"}], ",", 
